{
  "compilerOptions": {
    "target":           "ES2020",
    "module":           "ESNext",
    "moduleResolution": "bundler",
    "lib":              ["ES2020", "DOM"],
    "types": ["jest", "node"],
    "strict":           true,
    "esModuleInterop":  true,
    "skipLibCheck":     true,
    "noEmit":           true,
    "baseUrl":          ".",
    "jsx": "react-jsx",
    "paths": {
      "@verino/core":                          ["packages/core/src/index.ts"],
      "@verino/core/filter":                   ["packages/core/src/filter.ts"],
      "@verino/core/machine":                  ["packages/core/src/machine.ts"],
      "@verino/core/timer":                    ["packages/core/src/timer.ts"],
      "@verino/core/toolkit":                      ["packages/core/src/toolkit/index.ts"],
      "@verino/core/toolkit/controller":           ["packages/core/src/toolkit/controller.ts"],
      "@verino/core/toolkit/adapter-policy":       ["packages/core/src/toolkit/adapter-policy.ts"],
      "@verino/core/toolkit/timer-policy":         ["packages/core/src/toolkit/timer-policy.ts"],
      "@verino/core/toolkit/feedback":             ["packages/core/src/toolkit/feedback.ts"],
      "@verino/core/toolkit/password-manager":     ["packages/core/src/toolkit/password-manager.ts"],
      "@verino/vanilla":       ["packages/vanilla/src/index.ts"],
      "@verino/react":         ["packages/react/src/index.tsx"],
      "@verino/vue":           ["packages/vue/src/index.ts"],
      "@verino/svelte":        ["packages/svelte/src/index.ts"],
      "@verino/alpine":        ["packages/alpine/src/index.ts"],
      "@verino/web-component": ["packages/web-component/src/index.ts"]
    }
  },
  "include": ["tests/**/*.ts", "tests/**/*.tsx"]
}