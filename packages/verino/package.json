{
  "name": "verino",
  "version": "1.0.0",
  "description": "Reliable OTP inputs for any framework from a single core.",
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./core": {
      "types": "./dist/core/index.d.ts",
      "import": "./dist/core/index.js",
      "require": "./dist/core/index.cjs"
    },
    "./plugins": {
      "types": "./dist/adapters/plugins/index.d.ts",
      "import": "./dist/adapters/plugins/index.js",
      "require": "./dist/adapters/plugins/index.cjs"
    },
    "./plugins/timer-ui": {
      "types": "./dist/adapters/plugins/timer-ui.d.ts",
      "import": "./dist/adapters/plugins/timer-ui.js",
      "require": "./dist/adapters/plugins/timer-ui.cjs"
    },
    "./plugins/web-otp": {
      "types": "./dist/adapters/plugins/web-otp.d.ts",
      "import": "./dist/adapters/plugins/web-otp.js",
      "require": "./dist/adapters/plugins/web-otp.cjs"
    },
    "./plugins/pm-guard": {
      "types": "./dist/adapters/plugins/pm-guard.d.ts",
      "import": "./dist/adapters/plugins/pm-guard.js",
      "require": "./dist/adapters/plugins/pm-guard.cjs"
    }
  },
  "sideEffects": [
    "./dist/index.js",
    "./dist/adapters/vanilla.js"
  ],
  "files": [
    "dist",
    "src",
    "README.md",
    "LICENSE",
    "CHANGELOG.md"
  ],
  "scripts": {
    "build": "tsup",
    "typecheck": "tsc --noEmit"
  },
  "keywords": [
    "otp",
    "otp-input",
    "one-time-password",
    "one-time-code",
    "pin-input",
    "verification-code",
    "passcode",
    "2fa",
    "mfa",
    "sms-autofill",
    "web-otp",
    "autocomplete-one-time-code",
    "headless",
    "accessible-otp",
    "typescript",
    "zero-dependencies",
    "state-machine",
    "vanilla-otp"
  ],
  "author": "Olawale Balo",
  "license": "MIT",
  "homepage": "https://verino.vercel.app",
  "repository": {
    "type": "git",
    "url": "https://github.com/boastack/verino"
  },
  "bugs": {
    "url": "https://github.com/boastack/verino/issues"
  }
}
