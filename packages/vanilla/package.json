{
  "name": "@verino/vanilla",
  "version": "2.0.0",
  "description": "Vanilla JS adapter for Verino. Reliable OTP inputs from a single core.",
  "type": "module",
  "main": "./index.js",
  "module": "./index.js",
  "types": "./index.d.ts",
  "exports": {
    ".": {
      "types": "./index.d.ts",
      "import": "./index.js"
    },
    "./plugins": {
      "types": "./plugins.d.ts",
      "import": "./plugins.js"
    },
    "./plugins/types": {
      "types": "./plugins/types.d.ts"
    },
    "./plugins/timer-ui": {
      "types": "./dist/plugins/timer-ui.d.ts",
      "import": "./dist/plugins/timer-ui.js"
    },
    "./plugins/web-otp": {
      "types": "./dist/plugins/web-otp.d.ts",
      "import": "./dist/plugins/web-otp.js"
    },
    "./plugins/pm-guard": {
      "types": "./dist/plugins/pm-guard.d.ts",
      "import": "./dist/plugins/pm-guard.js"
    }
  },
  "sideEffects": [
    "./index.js"
  ],
  "files": [
    "index.js",
    "plugins.js",
    "dist/vanilla.js",
    "dist/plugins/timer-ui.js",
    "dist/plugins/web-otp.js",
    "dist/plugins/pm-guard.js",
    "dist/plugins/timer-ui.d.ts",
    "dist/plugins/web-otp.d.ts",
    "dist/plugins/pm-guard.d.ts",
    "dist/verino.min.js",
    "index.d.ts",
    "plugins.d.ts",
    "plugins/types.d.ts",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsup",
    "typecheck": "tsc -b"
  },
  "keywords": [
    "otp",
    "otp-input",
    "one-time-password",
    "one-time-code",
    "verification-code",
    "pin-input",
    "passcode",
    "2fa",
    "mfa",
    "authentication",
    "otp-field",
    "vanilla-otp",
    "sms-autofill",
    "web-otp",
    "accessible-otp",
    "typescript"
  ],
  "author": "Olawale Balo",
  "license": "MIT",
  "homepage": "https://verino.vercel.app",
  "repository": {
    "type": "git",
    "url": "https://github.com/boastack/verino",
    "directory": "packages/vanilla"
  },
  "bugs": {
    "url": "https://github.com/boastack/verino/issues"
  },
  "dependencies": {
    "@verino/core": "workspace:*"
  },
  "publishConfig": {
    "access": "public"
  }
}
