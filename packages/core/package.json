{
  "name": "@verino/core",
  "version": "1.0.0",
  "description": "Reliable OTP input state machine that powers React, Vue, Svelte, Alpine, Vanilla JS, and Web Components.",
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "sideEffects": false,
  "files": [
    "dist",
    "src",
    "README.md",
    "LICENSE",
    "CHANGELOG.md"
  ],
  "scripts": {
    "build": "tsup",
    "typecheck": "tsc --noEmit"
  },
  "keywords": [
    "otp",
    "otp-input",
    "one-time-password",
    "one-time-code",
    "pin-input",
    "verification-code",
    "passcode",
    "2fa",
    "mfa",
    "headless",
    "accessible-otp",
    "typescript",
    "zero-dependencies",
    "state-machine"
  ],
  "author": "Olawale Balo",
  "license": "MIT",
  "homepage": "https://verino.vercel.app",
  "repository": {
    "type": "git",
    "url": "https://github.com/boastack/verino",
    "directory": "packages/core"
  },
  "bugs": {
    "url": "https://github.com/boastack/verino/issues"
  },
  "publishConfig": {
    "access": "public"
  }
}
