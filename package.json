{
  "name": "verino",
  "description": "Reliable OTP inputs for any framework from a single core.",
  "private": true,
  "author": "Olawale Balo",
  "license": "MIT",
  "homepage": "https://verino.vercel.app",
  "repository": {
    "type": "git",
    "url": "https://github.com/boastack/verino"
  },
  "bugs": {
    "url": "https://github.com/boastack/verino/issues"
  },
  "engines": {
    "node": ">=18",
    "pnpm": ">=10"
  },
  "type": "module",
  "packageManager": "pnpm@10.13.1",
  "scripts": {
    "build": "turbo run build",
    "build:cdn": "node build-cdn.js",
    "build:all": "pnpm build && pnpm build:cdn",
    "typecheck": "turbo run typecheck",
    "lint": "pnpm typecheck",
    "test": "jest --no-coverage",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "test:e2e": "playwright test",
    "serve:test": "node scripts/serve-static.mjs",
    "dev": "turbo run build --watch",
    "release": "pnpm build:all && changeset publish",
    "size": "pnpm build:cdn && size-limit",
    "size:ci": "pnpm build:cdn && size-limit --json"
  },
  "size-limit": [
    {
      "name": "@verino/core (ESM)",
      "path": "packages/core/dist/index.js",
      "limit": "4 kB"
    },
    {
      "name": "@verino/vanilla (ESM)",
      "path": "packages/vanilla/dist/vanilla.js",
      "limit": "6 kB",
      "ignore": ["@verino/core"]
    },
    {
      "name": "plugin: timer-ui (ESM)",
      "path": "packages/vanilla/dist/plugins/timer-ui.js",
      "limit": "2 kB"
    },
    {
      "name": "plugin: web-otp (ESM)",
      "path": "packages/vanilla/dist/plugins/web-otp.js",
      "limit": "2 kB"
    },
    {
      "name": "plugin: pm-guard (ESM)",
      "path": "packages/vanilla/dist/plugins/pm-guard.js",
      "limit": "2 kB"
    },
    {
      "name": "@verino/react (ESM)",
      "path": "packages/react/dist/index.js",
      "limit": "4 kB",
      "ignore": ["react", "@verino/core"]
    },
    {
      "name": "@verino/vue (ESM)",
      "path": "packages/vue/dist/index.js",
      "limit": "4 kB",
      "ignore": ["vue", "@verino/core"]
    },
    {
      "name": "@verino/svelte (ESM)",
      "path": "packages/svelte/dist/index.js",
      "limit": "4 kB",
      "ignore": ["svelte", "@verino/core"]
    },
    {
      "name": "@verino/alpine (ESM)",
      "path": "packages/alpine/dist/index.js",
      "limit": "6 kB",
      "ignore": ["alpinejs", "@verino/core"]
    },
    {
      "name": "@verino/web-component (ESM)",
      "path": "packages/web-component/dist/index.js",
      "limit": "8 kB",
      "ignore": ["@verino/core"]
    },
    {
      "name": "CDN: verino.min.js",
      "path": "packages/vanilla/dist/verino.min.js",
      "limit": "12 kB"
    },
    {
      "name": "CDN: verino-alpine.min.js",
      "path": "packages/alpine/dist/verino-alpine.min.js",
      "limit": "10 kB"
    },
    {
      "name": "CDN: verino-wc.min.js",
      "path": "packages/web-component/dist/verino-wc.min.js",
      "limit": "12 kB"
    }
  ],
  "devDependencies": {
    "@changesets/cli": "^2.30.0",
    "esbuild": "^0.27.0",
    "@playwright/test": "^1.58.2",
    "@size-limit/preset-small-lib": "^11.0.0",
    "@testing-library/react": "^16.3.2",
    "@types/jest": "^30.0.0",
    "@types/node": "^20.0.0",
    "@types/react": "^18.0.0",
    "@types/react-dom": "^18.3.7",
    "jest": "^30.3.0",
    "jest-environment-jsdom": "^30.3.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "size-limit": "^11.0.0",
    "svelte": "^4.2.20",
    "ts-jest": "^29.4.6",
    "tsup": "^8.0.0",
    "turbo": "^2.0.0",
    "typescript": "^5.4.0",
    "vue": "^3.5.30"
  }
}
